<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- API Key -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="API Key (sk-or-…)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:endIconMode="password_toggle"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ai_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Model -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Model (e.g. google/gemini-flash-1.5)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ai_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Prompt label with tap-for-info -->
        <TextView
            android:id="@+id/ai_prompt_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prompt  (?)"
            android:textSize="14sp"
            android:textColor="?attr/textColor"
            android:layout_marginBottom="4dp"
            android:tooltipText="The prompt is sent before the selected text and its surrounding paragraph. The surrounding paragraph is detected from the nearest paragraph break on each side of your selection. Your selected text and paragraph are appended automatically — just write the instruction here." />

        <!-- Prompt field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="4dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ai_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top|start" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Prompt helper text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The prompt is prepended before your selection and surrounding paragraph context."
            android:textSize="12sp"
            android:textColor="?attr/grayTextColor"
            android:layout_marginBottom="8dp" />

        <!-- Reasoning toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Reasoning"
                android:textSize="14sp"
                android:textColor="?attr/textColor" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/ai_reasoning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Reset button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/ai_reset_prompt"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset Prompt to Default"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
