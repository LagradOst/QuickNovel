<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="2dp"

        android:focusable="true"
        android:clickable="true"
        android:id="@+id/download_result_root">

   <androidx.cardview.widget.CardView
           android:layout_width="match_parent"
           android:layout_height="match_parent"
           android:layout_marginBottom="2dp"
           app:cardElevation="0dp"
           app:cardCornerRadius="@dimen/roundedImageRadius"
           android:id="@+id/backgroundCard"
           android:foreground="?android:attr/selectableItemBackgroundBorderless"
           app:cardBackgroundColor="?attr/primaryGrayBackground">

       <!-- Imagen de fondo -->
       <ImageView
               android:duplicateParentState="true"
               android:id="@+id/imageView"
               android:scaleType="centerCrop"
               android:layout_width="match_parent"
               android:layout_height="match_parent"
               android:contentDescription="@string/poster_descript" />

       <!-- Contador de capítulos: arriba a la derecha -->
       <TextView
               android:id="@+id/progressReading"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:layout_gravity="top|end"
               android:layout_margin="6dp"
               android:paddingStart="6dp"
               android:paddingEnd="6dp"
               android:paddingTop="2dp"
               android:paddingBottom="2dp"
               android:textColor="@android:color/white"
               android:background="@drawable/download_chapterprogress_bg"
               tools:text="10/100" />

       <!-- Indicador / badge extra (se mantiene) -->
       <TextView
               android:padding="3dp"
               android:background="@drawable/download_add_bg"
               android:layout_margin="5dp"
               android:id="@+id/imageTextMore"
               android:textColor="@color/textColor"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content" />

       <!-- Barra de progreso horizontal (se mantiene) -->
       <androidx.core.widget.ContentLoadingProgressBar
               android:visibility="gone"
               android:indeterminate="true"
               style="@android:style/Widget.Material.ProgressBar.Horizontal"
               android:layout_gravity="bottom"
               android:layout_marginBottom="-7dp"
               android:indeterminateTint="?attr/colorPrimary"
               android:id="@+id/download_progressbar_indeterment"
               android:layout_width="match_parent"
               tools:progress="10"
               android:progressTint="?attr/colorPrimary"
               android:layout_height="15dp" />

       <!-- Small loading indicator (se mantiene) -->
       <androidx.core.widget.ContentLoadingProgressBar
               android:visibility="gone"
               tools:visibility="visible"
               android:padding="3dp"
               android:background="@drawable/download_add_bg"
               android:id="@+id/download_update_loading"
               android:layout_width="25dp"
               android:layout_height="25dp"
               android:layout_margin="5dp"
               style="@style/Widget.AppCompat.ProgressBar"
               android:foregroundTint="@color/white"
               android:progressTint="@color/white"
               android:layout_gravity="top|start" />

       <!-- TÍTULO: dentro de la imagen, en la parte inferior -->
       <TextView
               android:id="@+id/imageText"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:layout_gravity="bottom"
               android:paddingStart="8dp"
               android:paddingEnd="8dp"
               android:paddingTop="6dp"
               android:paddingBottom="6dp"
              
               android:ellipsize="end"
               android:maxLines="2"
               android:textColor="@android:color/white"
               android:textSize="13sp"
               android:background="@drawable/overlay_background_rounded2"
               android:gravity="center"
               android:text="The Perfect Run\nThe Perfect Run"
               tools:ignore="HardcodedText" />
   </androidx.cardview.widget.CardView>
<Space
    android:layout_width="match_parent"
    android:layout_height="8dp"/>
   
</LinearLayout>
